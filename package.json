{
  "name": "taplink",
  "version": "0.1.0",
  "description": "Chrome extension that prefetches visible same-origin links on arbitrary pages.",
  "license": "MIT",
  "author": "mkusaka <hinoshita1992@gmail.com>",
  "repository": "https://github.com/mkusaka/taplink.git",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint . --import-plugin --tsconfig ./tsconfig.json",
    "lint:fix": "oxlint . --import-plugin --tsconfig ./tsconfig.json --fix",
    "lint:ci": "oxlint . --import-plugin --tsconfig ./tsconfig.json --deny-warnings",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "package": "rm -f package.zip && pnpm build && cd dist && zip -r ../package.zip ."
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.2.0",
    "@testing-library/jest-dom": "6.8.0",
    "@types/chrome": "0.1.4",
    "@webext-core/fake-browser": "1.3.2",
    "happy-dom": "18.0.1",
    "oxlint": "1.14.0",
    "prettier": "3.6.2",
    "typescript": "5.9.2",
    "vite": "7.1.3",
    "vitest": "3.2.4"
  }
}
